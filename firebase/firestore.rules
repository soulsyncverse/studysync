// StudySync — Firestore Security Rules
// Deploy: firebase deploy --only firestore:rules

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth()        { return request.auth != null; }
    function isOwner(uid)    { return isAuth() && request.auth.uid == uid; }
    function isPro(uid)      {
      return isAuth() && get(/databases/$(database)/documents/users/$(uid)).data.isPro == true;
    }

    // ── Users ──────────────────────────────────────────────────
    match /users/{uid} {
      allow read, create, update: if isOwner(uid);
      allow delete: if false;

      match /tasks/{id}      { allow read, write: if isOwner(uid); }
      match /notes/{id}      { allow read, write: if isOwner(uid) && isPro(uid); }
      match /flashcards/{id} { allow read, write: if isOwner(uid) && isPro(uid); }
    }

    // ── Public Circle ──────────────────────────────────────────
    match /publicCircle/{uid} {
      allow read:  if isAuth();
      allow write: if isOwner(uid);
    }

    // ── Private Circles ────────────────────────────────────────
    match /circles/{circleId} {
      allow read:   if isAuth() && request.auth.uid in resource.data.members;
      allow create: if isAuth();
      allow update: if isAuth() && request.auth.uid == resource.data.createdBy;
      allow delete: if false;

      match /presence/{uid} {
        allow read:  if isAuth() && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.members;
        allow write: if isOwner(uid);
      }
      match /messages/{id} {
        allow read:   if isAuth() && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.members;
        allow create: if isAuth() && request.auth.uid in get(/databases/$(database)/documents/circles/$(circleId)).data.members;
        allow update, delete: if false;
      }
    }

    // ── Default: deny ─────────────────────────────────────────
    match /{doc=**} { allow read, write: if false; }
  }
}
