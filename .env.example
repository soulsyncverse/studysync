# ═══════════════════════════════════════════════════════════════
#  StudySync — Environment Variables
#  1. Copy this file:  cp .env.example .env.local
#  2. Fill in your real values below
#  3. Add all these to Vercel Dashboard → Settings → Environment Variables
#  4. NEVER commit .env.local to GitHub
# ═══════════════════════════════════════════════════════════════

# ── Anthropic Claude AI ─────────────────────────────────────────
# Get from: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Razorpay ────────────────────────────────────────────────────
# Get from: https://dashboard.razorpay.com → Settings → API Keys
# Use TEST keys during development:
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Firebase (from Firebase Console → Project Settings → Web App) ─
REACT_APP_FIREBASE_API_KEY=AIzaSy-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxxxxxxxxxx

# ── Security ─────────────────────────────────────────────────────
# Set to your real domain in production to prevent API abuse
# Example: https://studysync.vercel.app
ALLOWED_ORIGIN=*
